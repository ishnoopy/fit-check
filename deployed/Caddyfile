fit-check.ishnoopy.space {
    encode zstd gzip

    @staticAssets {
        path /_next/static/* /static/* *.css *.js *.mjs *.png *.jpg *.jpeg *.gif *.svg *.webp *.ico *.woff *.woff2
    }

    header @staticAssets Cache-Control "public, max-age=31536000, immutable"

    @html {
        path /
        path *.html
    }

    header @html Cache-Control "no-cache"

    handle /api/* {
        reverse_proxy backend-1:4000 backend-2:4001 {
            lb_policy round_robin
            health_uri /api/health
        }
    }

    handle {
        reverse_proxy frontend:3000
    }

    log {
        output stdout
        format json
    }
}
